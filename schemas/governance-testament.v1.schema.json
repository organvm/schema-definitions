{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://meta-organvm.github.io/schema-definitions/governance-testament.v1.schema.json",
  "title": "Governance Testament v1",
  "description": "Ratifiable constitutional record for directives, layers, instruments, ideal forms, supersession, predicates, and citations.",
  "type": "object",
  "required": [
    "contract_name", "contract_version", "testament_id", "version", "title", "status",
    "directive", "directive_hash", "layers", "instruments", "axioms", "ideal_form_references",
    "predicates", "citations"
  ],
  "properties": {
    "contract_name": {"const": "governance-testament.v1"},
    "contract_version": {"const": 1},
    "testament_id": {"type": "string", "minLength": 1},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "title": {"type": "string", "minLength": 1},
    "status": {"type": "string", "enum": ["draft", "candidate", "ratified", "superseded"]},
    "directive": {"type": "string", "minLength": 1},
    "directive_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "layers": {
      "type": "array",
      "minItems": 3,
      "contains": {"const": "ontology"},
      "items": {"type": "string", "enum": ["ontology", "cybernetics", "phenomenology"]},
      "uniqueItems": true
    },
    "instruments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["instrument_id", "reference", "status"],
        "properties": {
          "instrument_id": {"type": "string", "minLength": 1},
          "reference": {"type": "string", "minLength": 1},
          "status": {"type": "string", "enum": ["ratified", "partial", "missing", "superseded"]}
        },
        "additionalProperties": false
      }
    },
    "axioms": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["axiom_id", "statement", "citation_references"],
        "properties": {
          "axiom_id": {"type": "string", "minLength": 1},
          "statement": {"type": "string", "minLength": 1},
          "citation_references": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1},
            "uniqueItems": true
          }
        },
        "additionalProperties": false
      }
    },
    "ideal_form_references": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "ratification": {
      "type": "object",
      "required": [
        "ratified_at",
        "candidate_digest",
        "controlling_formulation",
        "assertion_evidence_reference",
        "authority_events",
        "constitutional_coverage",
        "constitutional_record_reference",
        "source_lineage_references",
        "approver_reference"
      ],
      "properties": {
        "ratified_at": {"type": "string", "format": "date-time"},
        "candidate_digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
        "controlling_formulation": {"type": "string", "minLength": 1},
        "assertion_evidence_reference": {"type": "string", "minLength": 1},
        "authority_events": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "object",
            "required": [
              "event_id",
              "source_envelope_reference",
              "role",
              "authority_class",
              "content_hash"
            ],
            "properties": {
              "event_id": {"type": "string", "pattern": "^evt_[a-f0-9]{64}$"},
              "source_envelope_reference": {"type": "string", "minLength": 1},
              "role": {"const": "operator"},
              "authority_class": {"const": "operator_intent"},
              "content_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"}
            },
            "additionalProperties": false
          }
        },
        "constitutional_coverage": {
          "type": "object",
          "required": [
            "scope_reference",
            "exact_all",
            "blocked_scopes",
            "missing_requirements",
            "ready"
          ],
          "properties": {
            "scope_reference": {"type": "string", "minLength": 1},
            "exact_all": {"type": "boolean"},
            "blocked_scopes": {
              "type": "array",
              "uniqueItems": true,
              "items": {"type": "string", "minLength": 1}
            },
            "missing_requirements": {
              "type": "array",
              "uniqueItems": true,
              "items": {"type": "string", "minLength": 1}
            },
            "ready": {"type": "boolean"}
          },
          "additionalProperties": false
        },
        "authority_event_reference": {"type": "string", "minLength": 1},
        "constitutional_record_reference": {"type": "string", "minLength": 1},
        "source_lineage_references": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        },
        "approver_reference": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "supersession": {
      "type": "object",
      "required": ["predecessor_references", "reason"],
      "properties": {
        "predecessor_references": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        },
        "reason": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "predicates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["predicate_id", "command", "expected_result"],
        "properties": {
          "predicate_id": {"type": "string", "minLength": 1},
          "command": {"type": "string", "minLength": 1},
          "expected_result": {"type": "string", "minLength": 1}
        },
        "additionalProperties": false
      }
    },
    "citations": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {"status": {"const": "candidate"}},
        "required": ["status"]
      },
      "then": {"not": {"required": ["ratification"]}}
    },
    {
      "if": {
        "properties": {"status": {"const": "ratified"}},
        "required": ["status"]
      },
      "then": {"required": ["ratification"]}
    },
    {
      "if": {"properties": {"status": {"const": "superseded"}}},
      "then": {"required": ["supersession"]}
    },
    {
      "properties": {
        "layers": {
          "allOf": [
            {"contains": {"const": "ontology"}},
            {"contains": {"const": "cybernetics"}},
            {"contains": {"const": "phenomenology"}}
          ]
        }
      }
    }
  ],
  "additionalProperties": false
}
