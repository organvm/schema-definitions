{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://meta-organvm.github.io/schema-definitions/lineage-graph.v1.schema.json",
  "title": "Lineage Graph v1",
  "description": "Reviewed dual-lane graph separating operator intent from artifacts while preserving chronology and evidence spans.",
  "type": "object",
  "required": ["contract_name", "contract_version", "graph_id", "generated_at", "frozen_snapshot_id", "nodes", "edges"],
  "properties": {
    "contract_name": {"const": "lineage-graph.v1"},
    "contract_version": {"const": 1},
    "graph_id": {"type": "string", "minLength": 1},
    "generated_at": {"type": "string", "format": "date-time"},
    "frozen_snapshot_id": {"type": "string", "minLength": 1},
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "node_id", "lane", "node_type", "source_envelope_id", "occurred_at",
          "authority_class", "summary", "content_hash", "review_state"
        ],
        "properties": {
          "node_id": {"type": "string", "minLength": 1},
          "lane": {"type": "string", "enum": ["operator_intent", "artifact"]},
          "node_type": {
            "type": "string",
            "enum": [
              "ask", "correction", "constraint", "acceptance_criterion", "human_gate",
              "plan", "brainstorm", "specification", "document", "commit", "issue",
              "pull_request", "implementation", "receipt", "source_event", "ideal_form"
            ]
          },
          "source_envelope_id": {"type": "string", "pattern": "^src_[A-Za-z0-9_-]+$"},
          "occurred_at": {"type": "string", "format": "date-time"},
          "authority_class": {
            "type": "string",
            "enum": ["operator_intent", "artifact", "transport_echo", "system_metadata", "unknown"]
          },
          "summary": {"type": "string", "minLength": 1},
          "content_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
          "review_state": {"type": "string", "enum": ["unreviewed", "reviewed", "rejected"]},
          "metadata": {"type": "object", "additionalProperties": true}
        },
        "allOf": [
          {
            "if": {"properties": {"lane": {"const": "operator_intent"}}},
            "then": {"properties": {"authority_class": {"const": "operator_intent"}}}
          },
          {
            "if": {"properties": {"node_type": {"enum": ["plan", "brainstorm", "specification", "document", "commit", "issue", "pull_request", "implementation", "receipt"]}}},
            "then": {"properties": {"lane": {"const": "artifact"}}}
          }
        ],
        "additionalProperties": false
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["edge_id", "from_node", "to_node", "edge_type", "evidence_spans", "confidence", "review_state"],
        "properties": {
          "edge_id": {"type": "string", "minLength": 1},
          "from_node": {"type": "string", "minLength": 1},
          "to_node": {"type": "string", "minLength": 1},
          "edge_type": {
            "type": "string",
            "enum": [
              "exact_duplicate", "transport_echo", "quotes", "references", "refines", "corrects",
              "supersedes", "splits", "merges", "contradicts", "implements", "adopts"
            ]
          },
          "evidence_spans": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["source_envelope_id", "reference", "body_hash"],
              "properties": {
                "source_envelope_id": {"type": "string", "pattern": "^src_[A-Za-z0-9_-]+$"},
                "reference": {"type": "string", "minLength": 1},
                "body_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
                "start_offset": {"type": "integer", "minimum": 0},
                "end_offset": {"type": "integer", "minimum": 0}
              },
              "additionalProperties": false
            }
          },
          "confidence": {"type": "number", "minimum": 0, "maximum": 1},
          "review_state": {"type": "string", "enum": ["unreviewed", "reviewed", "rejected"]},
          "reviewer_reference": {"type": "string", "minLength": 1}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
