{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://meta-organvm.github.io/schema-definitions/coverage-receipt.v1.schema.json",
  "title": "Coverage Receipt v1",
  "description": "Frozen-snapshot coverage account with a dynamic denominator, exactly-one source classifications, and owner-routed residuals.",
  "type": "object",
  "required": [
    "contract_name", "contract_version", "receipt_id", "snapshot_id", "generated_at",
    "denominator", "sources", "counts", "exact_all", "ready", "residual_owners", "receipt_hash"
  ],
  "properties": {
    "contract_name": {"const": "coverage-receipt.v1"},
    "contract_version": {"const": 1},
    "receipt_id": {"type": "string", "minLength": 1},
    "snapshot_id": {"type": "string", "minLength": 1},
    "generated_at": {"type": "string", "format": "date-time"},
    "denominator": {
      "type": "object",
      "required": ["discovery_manifest_reference", "count", "manifest_hash"],
      "properties": {
        "discovery_manifest_reference": {"type": "string", "minLength": 1},
        "count": {"type": "integer", "minimum": 0},
        "manifest_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"}
      },
      "additionalProperties": false
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source_id", "status", "accessible", "evidence_references"],
        "properties": {
          "source_id": {"type": "string", "pattern": "^src_[A-Za-z0-9_-]+$"},
          "status": {
            "type": "string",
            "enum": ["acquired", "parsed", "quarantined", "inaccessible", "missing_expected", "owner_blocked"]
          },
          "accessible": {"type": "boolean"},
          "owner_reference": {"type": "string", "minLength": 1},
          "failed_predicate": {"type": "string", "minLength": 1},
          "next_action": {"type": "string", "minLength": 1},
          "evidence_references": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1},
            "uniqueItems": true
          }
        },
        "allOf": [
          {
            "if": {"properties": {"status": {"not": {"const": "parsed"}}}},
            "then": {"required": ["owner_reference", "failed_predicate", "next_action"]}
          }
        ],
        "additionalProperties": false
      }
    },
    "counts": {
      "type": "object",
      "required": ["acquired", "parsed", "quarantined", "inaccessible", "missing_expected", "owner_blocked"],
      "properties": {
        "acquired": {"type": "integer", "minimum": 0},
        "parsed": {"type": "integer", "minimum": 0},
        "quarantined": {"type": "integer", "minimum": 0},
        "inaccessible": {"type": "integer", "minimum": 0},
        "missing_expected": {"type": "integer", "minimum": 0},
        "owner_blocked": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    },
    "exact_all": {"type": "boolean"},
    "ready": {
      "type": "boolean",
      "description": "True only when exact coverage is established and every discovered source is parsed with no residual owner debt."
    },
    "residual_owners": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source_id", "owner_reference", "failed_predicate", "next_action"],
        "properties": {
          "source_id": {"type": "string", "pattern": "^src_[A-Za-z0-9_-]+$"},
          "owner_reference": {"type": "string", "minLength": 1},
          "failed_predicate": {"type": "string", "minLength": 1},
          "next_action": {"type": "string", "minLength": 1}
        },
        "additionalProperties": false
      }
    },
    "receipt_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"}
  },
  "additionalProperties": false
}
